{
  "expo": {
    "name": "SafetyPaws",
    "slug": "safetypaws",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safetypaws",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safetypaws.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Take site photos for safety reports",
        "NSPhotoLibraryUsageDescription": "Select site photos for safety reports",
        "NSLocationWhenInUseUsageDescription": "Tag photos with location and get weather data"
      }
    },
    "android": {
      "package": "com.safetypaws.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash_image.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#87CEEB"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
